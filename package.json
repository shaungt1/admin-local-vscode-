{
  "name": "admin-local",
  "displayName": "Admin Local",
  "description": "Modular AI toolbox for multi-project developers and vibe-coders. Creates a private .admin-local workspace for API keys, prompts, scripts, and developer tools — Git-safe, Git-excluded, and portable between projects.",
  "version": "0.0.1",
  "publisher": "shaun.pritchard",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "api-keys",
    "prompts",
    "security",
    "git",
    "local",
    "secrets",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shaungt1/admin-local-vscode-"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "admin-local.init",
        "title": "(.Admin-Local) Initialize",
        "category": "Admin Local",
        "icon": "$(lock)"
      },
      {
        "command": "admin-local.delete",
        "title": "(.Admin-Local) Destroy",
        "category": "Admin Local",
        "icon": "$(trash)"
      },
      {
        "command": "admin-local.export",
        "title": "(.Admin-Local) Export",
        "category": "Admin Local",
        "icon": "$(export)"
      },
      {
        "command": "admin-local.import",
        "title": "(.Admin-Local) Import",
        "category": "Admin Local",
        "icon": "$(import)"
      },
      {
        "command": "admin-local.copyPrompt",
        "title": "(.Admin-Local) Copy Prompt to Clipboard",
        "category": "Admin Local",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "admin-local.init",
          "group": "2_adminlocal@1"
        },
        {
          "command": "admin-local.delete",
          "group": "2_adminlocal@2"
        },
        {
          "command": "admin-local.export",
          "group": "2_adminlocal@3"
        },
        {
          "command": "admin-local.import",
          "group": "2_adminlocal@4"
        },
        {
          "command": "admin-local.copyPrompt",
          "group": "2_adminlocal@5"
        }
      ],
      "commandPalette": [
        {
          "command": "admin-local.init"
        },
        {
          "command": "admin-local.delete"
        },
        {
          "command": "admin-local.export"
        },
        {
          "command": "admin-local.import"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "echo 'No linter configured yet'"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/extract-zip": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "extract-zip": "^2.0.1"
  }
}
